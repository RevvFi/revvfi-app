# ==============================================================
# .env.example  –  RevvFi Frontend environment template
# Copy to .env.local (local dev) or a testnet/production env file.
# Only NEXT_PUBLIC_* vars are usable here (Next.js inlines them at build time -
# never put secrets in this file, they'd ship to the browser).
# ==============================================================

# ------------------------------------------------------------
# MUST CHANGE for testnet/production
# ------------------------------------------------------------

# --- Backend API ---
NEXT_PUBLIC_API_URL=                        # real deployed backend URL, e.g. https://api.revvfi.com/api/v1

# --- Active chain ---
# Controls which chain the whole app targets (see constants/chains.ts) - every
# hook that reads `localChain.id` automatically follows this.
NEXT_PUBLIC_CHAIN_ID=11155111                # Sepolia. Must match the backend's CHAIN_ID/AUTH_CHAIN_ID.
NEXT_PUBLIC_RPC_URL=                         # real Sepolia RPC URL for the active chain's transport
NEXT_PUBLIC_SEPOLIA_RPC_URL=                 # optional: API-key-backed RPC for the sepolia wagmi transport
                                              # (falls back to viem's public/rate-limited default if unset)
NEXT_PUBLIC_MAINNET_RPC_URL=                 # optional: same, for the mainnet transport

# --- Contract addresses (fill in after running the contracts deploy script) ---
NEXT_PUBLIC_ARCH_CONTROLLER_ADDRESS=
NEXT_PUBLIC_FACTORY_ADDRESS=
NEXT_PUBLIC_POSITION_NFT_ADDRESS=
NEXT_PUBLIC_LIQUIDATOR_ADDRESS=
NEXT_PUBLIC_REPUTATION_REGISTRY_ADDRESS=
NEXT_PUBLIC_USDC_ADDRESS=
NEXT_PUBLIC_WETH_ADDRESS=
NEXT_PUBLIC_COLLATERAL_ORACLE_ADDRESS=       # Chainlink feed used by WETH-collateral markets
NEXT_PUBLIC_COLLATERAL_ORACLE_ADDRESS_USDC=  # Chainlink feed (or reciprocal) used by USDC-collateral markets
NEXT_PUBLIC_DEFAULT_MARKET_ADDRESS=          # leave blank if no market is pre-deployed

# --- Admin ---
NEXT_PUBLIC_ADMIN_WALLETS=                   # comma-separated real admin wallet addresses (currently unused by
                                              # the app itself - admin gating is backend/role-driven - but kept
                                              # here for parity with the backend's ADMIN_WALLETS)

# --- External sites (required - no fallback, see constants/links.ts) ---
NEXT_PUBLIC_LANDING_URL=https://revvfi.xyz           # marketing/landing site the logo and footer links point to
NEXT_PUBLIC_FAUCET_URL=https://faucet.revvfi.xyz     # Sepolia testnet faucet linked from Borrow/Lend/Settings

# ------------------------------------------------------------
# Safe defaults (rarely need changing)
# ------------------------------------------------------------

# WalletConnect project id - a public identifier, not a secret. Get one at
# https://cloud.walletconnect.com if you don't already have one.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Only used as a local-dev fallback when NEXT_PUBLIC_RPC_URL is unset.
NEXT_PUBLIC_LOCAL_RPC_URL=http://127.0.0.1:8545

NEXT_PUBLIC_ENVIRONMENT=development          # currently just a display value, not consumed for gating logic
